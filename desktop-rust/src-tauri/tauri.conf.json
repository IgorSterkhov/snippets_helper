{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keyboard Helper",
  "version": "0.9.8",
  "identifier": "com.keyboard-helper.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Keyboard Helper",
        "url": "khapp://localhost/index.html",
        "width": 900,
        "height": 600,
        "visible": false,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self' khapp://localhost; script-src 'self' khapp://localhost; style-src 'self' khapp://localhost 'unsafe-inline'; connect-src 'self' khapp://localhost ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/IgorSterkhov/snippets_helper/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3NTg2MkUxRjZGQjAxMDgKUldRSUFmdjI0V0pZTjRWWTBuSmt2dmQ1ZmdjdlJvc0lza0EzNEc5R3RTOVMrQjlYbkF6VnAwOFcK"
    }
  }
}
